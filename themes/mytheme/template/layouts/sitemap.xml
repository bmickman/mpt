{{- $p := .Site.RegularPages -}}
{{- $now := now.Format "2006-01-02T15:04:05Z07:00" -}}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- range $p }}
  {{- if not .Params.draft }}
  <url>
    <loc>{{ .Permalink | safeURL }}</loc>
    <lastmod>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
    <changefreq>{{ with .Params.changefreq }}{{ . }}{{ else }}weekly{{ end }}</changefreq>
    <priority>{{ with .Params.priority }}{{ . }}{{ else }}0.5{{ end }}</priority>
  </url>
  {{- end }}
{{- end }}
</urlset>